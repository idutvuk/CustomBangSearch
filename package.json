{
	"name": "custombangsearch",
	"version": "0.11.3",
	"description": "A browser extension that lets you use custom DuckDuckGo-style bangs directly from the address bar",
	"packageManager": "bun@1.3.8",
	"main": "",
	"scripts": {
		"test": "",
		"lint": "bunx biome lint ./src",
		"tsc-noemit": "bunx tsc -noEmit",
		"build-firefox": "bun ./bob.mjs -d -b firefox",
		"build-firefox-release": "bun ./bob.mjs -z -s -b firefox",
		"build-chrome": "bun ./bob.mjs -d -b chrome",
		"build-chrome-release": "bun ./bob.mjs -z -s -b chrome"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/psidex/CustomBangSearch.git"
	},
	"keywords": [
		"chrome",
		"firefox",
		"extension",
		"addon",
		"browser-extension",
		"web-extension",
		"chrome-extension",
		"firefox-extension",
		"firefox-addon",
		"search",
		"custom-search",
		"duckduckgo",
		"bang",
		"bangs"
	],
	"author": "psidex",
	"license": "GPL-3.0",
	"bugs": {
		"url": "https://github.com/psidex/CustomBangSearch/issues"
	},
	"homepage": "https://github.com/psidex/CustomBangSearch#readme",
	"dependencies": {
		"@mantine/core": "8.3.18",
		"@mantine/hooks": "8.3.18",
		"@mantine/notifications": "8.3.18",
		"@uidotdev/usehooks": "^2.4.1",
		"lucide-react": "0.577.0",
		"lz-string": "^1.5.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-virtuoso": "^4.18.3",
		"webextension-polyfill": "0.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/webextension-polyfill": "0.12.5",
		"esbuild": "0.27.4",
		"execa": "9.6.1",
		"fs-extra": "11.3.4",
		"listr2": "10.2.1",
		"postcss": "^8.5.8",
		"postcss-cli": "^11.0.1",
		"postcss-preset-mantine": "^1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"typescript": "5.9.3"
	}
}
